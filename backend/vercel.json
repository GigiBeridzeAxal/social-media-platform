{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ],
  "env": {
    "JWT_EXPIRES_IN": "7d",
    "FRONTEND_URL": "*",
    "NODE_ENV": "production",
    "DB_NAME": "socialsphere"
  }
}
