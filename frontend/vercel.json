  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": "https://socialsphere-backend.vercel.app",
    "VITE_BYPASS_SECRET": "socialsphere-bypass-2024"
  }
}
