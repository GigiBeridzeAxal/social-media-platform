{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://socialsphere-backend.vercel.app/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "",
      "VITE_APP_NAME": "SocialSphere",
      "VITE_SOCKET_URL": ""
    }
  }
}
